COMPOSE_PROJECT_NAME=hsi-stack

WEB_PORT=80
SERVER_PORT=8080
MODEL_PORT=5000
RAG_PORT=5001
MYSQL_PORT=3306
REDIS_PORT=6379

MYSQL_DATABASE=hsi_detection_system
MYSQL_USER=root
MYSQL_PASSWORD=root123456

VITE_APP_BASE_API=/api
VITE_APP_API_URL=http://server:8080
VITE_RAG_API=/api/rag
OLLAMA_BASE_URL=http://host.docker.internal:11434

EMBEDDING_MODEL=qwen3-embedding:0.6b
LLM_MODEL=qwen3:8b
CHUNK_SIZE=500
CHUNK_OVERLAP=50
USE_REDIS=true
MAX_HISTORY_MESSAGES=20
SESSION_ID=default_session
